# Only secrets live in env — everything else is in /data/settings.json (Docker
# named volume) and editable at runtime via the update_settings MCP tool.

HYPERLIQUID_PRIVATE_KEY=0x_your_agent_wallet_private_key
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet_address

# Optional ops overrides (uncomment if you need them — these beat settings.json)
# HYPERLIQUID_NETWORK=mainnet      # mainnet|testnet
# LIVE_TRADING=false               # emergency kill-switch overriding settings.live_trading
