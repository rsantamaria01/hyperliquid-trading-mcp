# === Required ===
HYPERLIQUID_PRIVATE_KEY=0x_your_agent_wallet_private_key
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet_address

# === Trading mode ===
LIVE_TRADING=false              # set "true" to send real orders; otherwise dry-run
HYPERLIQUID_NETWORK=mainnet     # mainnet or testnet

# === Risk caps (sensible defaults) ===
MAX_POSITION_PCT=10
MAX_LOSS_PER_POSITION_PCT=20
MAX_LEVERAGE=10
MAX_TOTAL_EXPOSURE_PCT=50
DAILY_LOSS_CIRCUIT_BREAKER_PCT=10
MANDATORY_SL_PCT=5
MAX_CONCURRENT_POSITIONS=10
MIN_BALANCE_RESERVE_PCT=20
